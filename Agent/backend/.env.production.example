# 复制为 .env 后填写真实值；此文件仅作模板，不能提交真实密码。
APP_ENV=production
LOCAL_AUTO_LOGIN=false
DATABASE_URL=postgresql+psycopg://assessment_user:请替换数据库密码@127.0.0.1:5432/ppp_rural_sewage
STORAGE_DIR=/data/ppp-rural-sewage/storage
SECRET_KEY=请替换为至少32位随机字符串
ACCESS_TOKEN_EXPIRE_MINUTES=720
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
ADMIN_INITIAL_PASSWORD=请替换为管理员初始密码
INSPECTOR_INITIAL_PASSWORD=请替换为采集员初始密码
CORS_ORIGINS=https://your-domain.example
CORS_ORIGIN_REGEX=
CELERY_TASK_ALWAYS_EAGER=false
MAX_UPLOAD_SIZE_MB=200
